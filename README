Debe tener Node.js 
__________________________________
Instalar dependencias
npm install express mysql2 dotenv
npm install --save-dev nodemon

__________________________________
DB XAMPP
CREATE DATABASE motosmart;

USE motosmart;

CREATE TABLE motos (
  id INT AUTO_INCREMENT PRIMARY KEY,
  marca VARCHAR(100),
  modelo VARCHAR(100),
  cilindraje INT
);

__________________________________
Para doocker  
docker-compose up --build


docker exec -it motosmart_db mysql -u root -p
Contraseña: root (Cuando se ingrese no la deja ver por ende debes confiar en el proceso :D ) 

USE motosmart;

CREATE TABLE motos (
  id INT AUTO_INCREMENT PRIMARY KEY,
  marca VARCHAR(100),
  modelo VARCHAR(100),
  cilindraje INT
);